{
    "name": "sid-server",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "lint": "eslint src",
        "test": "cross-env DATABASE_PATH=:memory: tap"
    },
    "dependencies": {
        "@types/supertest": "^7.2.0",
        "better-sqlite3": "^11.0.0",
        "cors": "^2.8.5",
        "cross-env": "^10.1.0",
        "express": "^4.21.0",
        "supertest": "^7.2.2"
    },
    "tap": {
        "reporter": "tap",
        "disable-coverage": true,
        "node-arg": [
            "--require",
            "tsx/cjs"
        ],
        "include": [
            "src/**/*.test.ts"
        ]
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "tap": "^18.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "typescript-eslint": "^8.0.0"
    }
}
